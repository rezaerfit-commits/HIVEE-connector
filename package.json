{
  "name": "hivee-connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Edge connector that bridges Hivee Cloud to a local OpenClaw runtime.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint:types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  }
}
